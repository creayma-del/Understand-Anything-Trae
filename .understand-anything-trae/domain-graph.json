{
  "version": "1.0.0",
  "project": {
    "name": "Understand Anything Trae",
    "description": "将任意代码库、知识库或文档转化为可交互的知识图谱，支持探索、搜索和提问",
    "languages": ["typescript", "javascript", "python", "css", "html", "shell", "yaml", "json", "markdown"],
    "frameworks": ["React", "Vite", "Tree-sitter", "Graphology", "Vitest"]
  },
  "nodes": [
    {
      "id": "domain:code-parsing-structure-extraction",
      "type": "domain",
      "name": "代码解析与结构提取",
      "summary": "负责识别编程语言、加载对应配置与 Tree-sitter 解析器、遍历 AST 提取函数/类/导入/导出等结构信息，以及解析非代码文件（YAML、JSON、Markdown 等）的结构分区。是整个知识图谱生成流水线的数据采集基础。",
      "tags": ["解析", "AST", "Tree-sitter", "结构提取"],
      "complexity": "complex"
    },
    {
      "id": "domain:knowledge-graph-construction",
      "type": "domain",
      "name": "知识图谱构建与分析",
      "summary": "将结构提取结果组装为知识图谱，包含节点创建、边关系建立、Schema 校验与自动修复、图标准化归一化、模糊搜索与语义搜索等核心能力。是项目的核心数据模型与处理引擎。",
      "tags": ["知识图谱", "Schema", "校验", "搜索"],
      "complexity": "complex"
    },
    {
      "id": "domain:visualization-dashboard",
      "type": "domain",
      "name": "可视化仪表盘",
      "summary": "基于 React + React Flow 的交互式知识图谱可视化前端，支持层聚合概览与层详情钻取两种导航层级、域图谱视图、搜索筛选、路径查找、导出、主题切换、国际化与移动端适配。",
      "tags": ["可视化", "React", "仪表盘", "交互"],
      "complexity": "complex"
    },
    {
      "id": "domain:multi-agent-pipeline",
      "type": "domain",
      "name": "多智能体分析流水线",
      "summary": "编排多个 LLM Agent 与确定性脚本协同工作的端到端流水线，包括项目扫描、批次计算、文件分析、图谱合并、架构识别、导览生成和图谱审查。Agent 定义以 Markdown 提示词模板形式存在，脚本负责确定性计算步骤。",
      "tags": ["Agent", "LLM", "流水线", "编排"],
      "complexity": "complex"
    },
    {
      "id": "domain:incremental-update",
      "type": "domain",
      "name": "增量更新与变更检测",
      "summary": "通过文件指纹（SHA-256 哈希 + 结构签名）实现增量变更检测，区分无变更/外观变更/结构变更三级，根据变更分类决定图谱更新策略（跳过/部分更新/架构更新/全量更新），并执行增量图谱合并。",
      "tags": ["增量更新", "指纹", "变更检测", "优化"],
      "complexity": "moderate"
    },

    {
      "id": "flow:language-identification-config-loading",
      "type": "flow",
      "name": "语言识别与配置加载",
      "summary": "将 17 种内置语言配置注册到 LanguageRegistry，根据文件扩展名或文件名自动匹配语言，加载对应的 Tree-sitter WASM 解析器，为后续结构提取提供语言上下文。",
      "tags": ["语言配置", "注册表", "Tree-sitter"],
      "complexity": "moderate"
    },
    {
      "id": "flow:code-structure-extraction",
      "type": "flow",
      "name": "代码结构提取",
      "summary": "基于 Tree-sitter AST 遍历，提取函数声明（含类型注解、装饰器）、类声明（含方法、属性）、导入语句、导出语句和调用图，将结果转换为统一的 StructuralAnalysis 数据结构。",
      "tags": ["AST", "函数提取", "类提取", "调用图"],
      "complexity": "complex"
    },
    {
      "id": "flow:non-code-file-parsing",
      "type": "flow",
      "name": "非代码文件解析",
      "summary": "通过 PluginRegistry 将非代码文件（YAML、JSON/JSONC、TOML、Markdown、Dockerfile、Env、SQL、GraphQL、Makefile、Shell）路由到对应的解析器，提取结构化分区信息（标题、键、节等）。",
      "tags": ["解析器", "非代码", "分区提取"],
      "complexity": "moderate"
    },
    {
      "id": "flow:framework-detection",
      "type": "flow",
      "name": "框架检测与识别",
      "summary": "通过 FrameworkRegistry 扫描项目清单文件中的关键词，自动检测使用的框架（React、Vue、Next.js、Express、Django、FastAPI、Flask 等），为后续分析提供框架上下文提示。",
      "tags": ["框架", "自动检测", "注册表"],
      "complexity": "simple"
    },

    {
      "id": "flow:graph-construction",
      "type": "flow",
      "name": "图谱构建",
      "summary": "GraphBuilder 从文件列表和结构分析结果构建知识图谱，为代码文件创建函数/类子节点和 contains 边，为非代码文件创建定义/服务/端点/步骤/资源子节点，同时建立 import 和 call 边。",
      "tags": ["图谱构建", "节点创建", "边建立"],
      "complexity": "complex"
    },
    {
      "id": "flow:graph-validation-repair",
      "type": "flow",
      "name": "图谱校验与修复",
      "summary": "对知识图谱执行三阶段校验管线：先清洗数据（sanitizeGraph），再自动修复已知问题（autoFixGraph，如节点/边类型别名归一化、权重范围修正、悬空边删除），最后执行严格 Schema 校验（validateGraph）。",
      "tags": ["校验", "修复", "Schema"],
      "complexity": "moderate"
    },
    {
      "id": "flow:graph-normalization",
      "type": "flow",
      "name": "图谱标准化",
      "summary": "对批次输出执行标准化处理：节点 ID 规范化（处理双前缀、项目名前缀、裸路径）、复杂度归一化（字符串别名/数值映射）、去重、悬空边删除和边引用重写，确保合并后的图谱数据一致。",
      "tags": ["标准化", "归一化", "去重"],
      "complexity": "moderate"
    },
    {
      "id": "flow:search-retrieval",
      "type": "flow",
      "name": "搜索与检索",
      "summary": "提供两种搜索能力：基于 Fuse.js 的模糊搜索（按名称、标签、摘要加权匹配）和基于向量嵌入的语义搜索（余弦相似度），支持类型过滤和结果数量限制。",
      "tags": ["模糊搜索", "语义搜索", "Fuse.js"],
      "complexity": "moderate"
    },

    {
      "id": "flow:graph-view-rendering",
      "type": "flow",
      "name": "图谱视图渲染",
      "summary": "核心图谱可视化流程，包含概览层（层聚合为集群节点）和层详情（文件级拓扑 + ELK 两阶段布局）两种导航层级，支持容器展开/收起、Portal 跨层连接和搜索高亮。",
      "tags": ["图谱视图", "ELK布局", "层聚合"],
      "complexity": "complex"
    },
    {
      "id": "flow:domain-graph-view",
      "type": "flow",
      "name": "域图谱视图",
      "summary": "领域图谱的交互式可视化，提供概览和详情两种布局模式，注册自定义节点类型（DomainClusterNode、FlowNode、StepNode），使用 ELK 算法进行自动布局，支持单击选中与双击导航。",
      "tags": ["域图谱", "领域视图", "流程可视化"],
      "complexity": "moderate"
    },
    {
      "id": "flow:interaction-navigation",
      "type": "flow",
      "name": "交互与导航",
      "summary": "用户交互功能集：节点选中与详情展示（NodeInfo）、搜索与筛选（SearchBar + FilterPanel）、BFS 路径查找（PathFinderModal）、导出为 SVG/PNG/JSON（ExportMenu）、键盘快捷键和导览步骤高亮。",
      "tags": ["交互", "导航", "搜索", "导出"],
      "complexity": "moderate"
    },
    {
      "id": "flow:theme-i18n-system",
      "type": "flow",
      "name": "主题与国际化",
      "summary": "主题引擎将 ThemeConfig 解析为 CSS 自定义属性并应用到文档根元素，支持 5 套预设主题和强调色切换；国际化模块提供中英文语言包，通过 React Context 分发给子组件。",
      "tags": ["主题", "国际化", "CSS变量"],
      "complexity": "simple"
    },

    {
      "id": "flow:project-scanning-batching",
      "type": "flow",
      "name": "项目扫描与批次计算",
      "summary": "确定性扫描脚本枚举项目文件、检测语言和框架、计算复杂度；导入映射脚本提取文件间依赖关系；批次计算脚本基于 Louvain 社区检测对导入图聚类，生成语义化的文件批次划分。",
      "tags": ["扫描", "Louvain", "批次", "导入图"],
      "complexity": "complex"
    },
    {
      "id": "flow:file-analysis-assembly",
      "type": "flow",
      "name": "文件分析与图谱组装",
      "summary": "每个批次先运行确定性结构提取脚本（extract-structure.mjs），再由 LLM Agent 生成摘要和关系；批次图合并脚本（merge-batch-graphs.py）执行 ID 规范化、复杂度标准化、边去重与悬空清理，并恢复遗漏的导入边。",
      "tags": ["文件分析", "LLM", "合并", "规范化"],
      "complexity": "complex"
    },
    {
      "id": "flow:architecture-tour-generation",
      "type": "flow",
      "name": "架构识别与导览生成",
      "summary": "层级检测模块先执行启发式目录模式匹配，再由 LLM 辅助将文件分配到架构层；导览生成模块基于拓扑排序和层级分组设计 5-15 步引导式学习路径；图谱审查器执行 9 项验证确保质量。",
      "tags": ["架构", "层级检测", "导览", "审查"],
      "complexity": "complex"
    },
    {
      "id": "flow:diff-impact-analysis",
      "type": "flow",
      "name": "差异影响分析",
      "summary": "将变更文件列表映射到知识图谱节点，识别涟漪效应（1-hop 受影响节点、受影响层、受影响边），生成结构化的 DiffContext 并格式化为 Markdown 报告，供 Dashboard 的 Diff 覆盖层展示。",
      "tags": ["差异分析", "影响范围", "涟漪效应"],
      "complexity": "moderate"
    },

    {
      "id": "flow:fingerprint-computation",
      "type": "flow",
      "name": "文件指纹计算",
      "summary": "通过 SHA-256 内容哈希和结构签名（函数/类/导入/导出列表）为每个文件生成唯一指纹，对比新旧指纹可判定变更级别：NONE（无变更）、COSMETIC（仅外观变更）、STRUCTURAL（结构变更）。",
      "tags": ["指纹", "SHA-256", "变更级别"],
      "complexity": "moderate"
    },
    {
      "id": "flow:change-classification-update",
      "type": "flow",
      "name": "变更分类与更新策略",
      "summary": "根据变更分析结果（变更文件数量、比例、目录结构变化）决定图谱更新策略：SKIP（无变更跳过）、PARTIAL_UPDATE（部分更新）、ARCHITECTURE_UPDATE（架构层更新）、FULL_UPDATE（全量重建），并执行增量图谱合并。",
      "tags": ["变更分类", "更新策略", "增量合并"],
      "complexity": "moderate"
    },

